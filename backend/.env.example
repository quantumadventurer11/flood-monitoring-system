# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/flood_monitoring
POSTGRES_USER=username
POSTGRES_PASSWORD=password
POSTGRES_DB=flood_monitoring
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Copernicus Data Space Ecosystem
CDSE_CLIENT_ID=your-cdse-client-id
CDSE_CLIENT_SECRET=your-cdse-client-secret

# Application Settings
APP_NAME="Flood Monitoring System"
DEBUG=False
CORS_ORIGINS=["http://localhost:3000","https://your-frontend-domain.com"]

# Email Configuration (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Map Settings
DEFAULT_LATITUDE=23.6850
DEFAULT_LONGITUDE=90.3563
DEFAULT_ZOOM=8